PORT=4000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_SESSION_KEY=replace-with-a-long-random-secret

CLIENT_BASE_URL=https://ideahubs.org
SERVER_BASE_URL=https://api.ideahubs.org
OAUTH_SUCCESS_REDIRECT=https://ideahubs.org/oauth/callback

EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@ideahubs.org
RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

ENABLE_AI_WORKER=true
AI_WORKER_POLL_MS=4000
AI_JOB_MAX_ATTEMPTS=3

# ── AI provider（provider-agnostic，由 src/services/aiClient.js 统一读取）────────
# 所有 AI service 走 /v1/chat/completions（各家「OpenAI 兼容」端点的最大公约数；
# 它们大多没有 OpenAI 专有的 /v1/responses）。换厂商只需改这三个变量，不用动代码。
#
# AI_BASE_URL  兼容端点地址；留空 = 用 SDK 默认（OpenAI 官方 https://api.openai.com/v1）
# AI_API_KEY   该 provider 的 API Key
# AI_MODEL     模型名；留空则用各调用点内置的默认模型
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# 向后兼容：未设置 AI_* 时自动回退到下面的 OPENAI_*（AI_* 优先）。
# 老部署可原样保留 OPENAI_API_KEY / OPENAI_MODEL 继续跑。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
# OPENAI_BASE_URL=

# ── 国内厂商示例（取消注释其一，并把 key 填到 AI_API_KEY）─────────────────────
# ⚠️ 以下 URL 与模型名仅为示例，一切以各厂商【当时的官方文档】为准。
#
# DeepSeek
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
#
# 阿里云百炼 / 通义千问
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus
#
# 火山方舟 / 豆包（AI_MODEL 填「推理接入点 ID」，不是模型名）
# AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# AI_MODEL=<推理接入点ID>
#
# 智谱 GLM
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-plus

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OTP_PEPPER=replace-with-a-long-random-secret
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ── 手机号短信登录（短信验证码）─────────────────────────────────────────
# SMS_PROVIDER：dev（默认，只在服务器日志打印验证码、不真发）| aliyun-pnvs | off
# 生产要真发短信必须切到 aliyun-pnvs 并配好下面的 key/签名/模板，否则 capabilities.phoneEnabled=false、
# 前端不显示「手机登录」入口（避免给出发不出码的死按钮）。
SMS_PROVIDER=dev
#
# 阿里云「号码认证服务 PNVS · 短信认证」——个人实名即可用，免申请签名/模板/运营商报备。
# 开通后在控制台拿 AccessKey 与【系统赠送】的签名名/模板号填入：
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_PNVS_SIGN_NAME=          # 短信签名（SendSmsVerifyCode 必填）
# ALIYUN_PNVS_TEMPLATE_CODE=      # 短信模板 CODE（如 100001 / SMS_xxxx，必填）
# ALIYUN_PNVS_SCHEME_NAME=        # 可选：方案名（若填，发送与校验必须一致）
# ALIYUN_PNVS_TEMPLATE_PARAM=     # 可选：模板参数 JSON，默认 {"code":"##code##"}；模板另有变量时覆盖
# ALIYUN_PNVS_REGION=cn-hangzhou  # 可选
# ALIYUN_PNVS_VERSION=2017-05-25  # 可选
# ALIYUN_PNVS_ENDPOINT=https://dypnsapi.aliyuncs.com/  # 可选
