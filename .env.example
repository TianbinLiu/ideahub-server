GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

ENABLE_AI_WORKER=true
AI_WORKER_POLL_MS=4000
AI_JOB_MAX_ATTEMPTS=3
